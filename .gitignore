results/
*.h5

# Notebook output figures (regenerable)
Figures/
Figures_*/

# New-run figure data and checkpoints (local, not shipped)
figure_data_*/
checkpoints/newrun_*.pt
checkpoints/test_run.pt

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Allow the shipped checkpoints and figure_data
!checkpoints/
!checkpoints/**
!figure_data/
